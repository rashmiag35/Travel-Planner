<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground — Travel Planner (Option 1: Globe & Flight Arc)
  Canvas: 108×108dp. The safe zone for adaptive icons is the centre 72×72dp
  (18dp inset on each side), so all artwork is kept within that area.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Globe outline circle ── -->
    <path
        android:pathData="M54,26 m-28,0 a28,28 0 1,0 56,0 a28,28 0 1,0 -56,0"
        android:strokeColor="#B2DFDB"
        android:strokeWidth="1.6"
        android:fillColor="#00000000"
        android:strokeAlpha="0.5" />

    <!-- Globe vertical longitude arc (left) -->
    <path
        android:pathData="M54,26 Q47,40 47,54 Q47,68 54,82"
        android:strokeColor="#B2DFDB"
        android:strokeWidth="1.2"
        android:fillColor="#00000000"
        android:strokeAlpha="0.4" />

    <!-- Globe vertical longitude arc (right) -->
    <path
        android:pathData="M54,26 Q61,40 61,54 Q61,68 54,82"
        android:strokeColor="#B2DFDB"
        android:strokeWidth="1.2"
        android:fillColor="#00000000"
        android:strokeAlpha="0.4" />

    <!-- Globe horizontal equator line -->
    <path
        android:pathData="M26,54 L82,54"
        android:strokeColor="#B2DFDB"
        android:strokeWidth="1.1"
        android:fillColor="#00000000"
        android:strokeAlpha="0.35" />

    <!-- Upper latitude arc -->
    <path
        android:pathData="M28,42 Q54,37 80,42"
        android:strokeColor="#B2DFDB"
        android:strokeWidth="1"
        android:fillColor="#00000000"
        android:strokeAlpha="0.3" />

    <!-- Lower latitude arc -->
    <path
        android:pathData="M28,66 Q54,71 80,66"
        android:strokeColor="#B2DFDB"
        android:strokeWidth="1"
        android:fillColor="#00000000"
        android:strokeAlpha="0.3" />

    <!-- ── Dashed flight arc (amber) ── drawn as two dashes -->
    <path
        android:pathData="M30,76 C36,38 70,28 82,34"
        android:strokeColor="#E65100"
        android:strokeWidth="2.4"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />

    <!-- ── Aeroplane (amber) at top-right of arc ── -->
    <!-- Body -->
    <path
        android:pathData="M78,31 L88,27 L86,33 Z"
        android:fillColor="#FFB74D" />
    <!-- Wing top -->
    <path
        android:pathData="M82,29 L90,24 L90,29 Z"
        android:fillColor="#FFB74D" />
    <!-- Wing bottom -->
    <path
        android:pathData="M82,31 L90,36 L90,31 Z"
        android:fillColor="#FFB74D" />
    <!-- Tail -->
    <path
        android:pathData="M78,31 L74,28 L76,31 Z"
        android:fillColor="#FFB74D" />

    <!-- ── Location pin (white) at bottom-left of arc ── -->
    <!-- Pin head (teardrop) -->
    <path
        android:pathData="M30,76 m0,-12 a6,6 0 0,1 0,12 a6,6 0 0,1 0,-12z"
        android:fillColor="#FFFFFF" />
    <!-- Pin inner dot (teal) -->
    <path
        android:pathData="M30,70 m0,-3 a3,3 0 0,1 0,6 a3,3 0 0,1 0,-6z"
        android:fillColor="#00695C" />
    <!-- Pin tail -->
    <path
        android:pathData="M30,76 L30,83"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />

</vector>
